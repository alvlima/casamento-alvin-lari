# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# URL base da API PHP no HostGator (sem barra no final)
# Desenvolvimento local: deixar em branco para usar mock data
VITE_API_BASE_URL=https://seudominio.com.br/api

# Chave PÚBLICA do Mercado Pago — segura para o frontend (diferente do ACCESS_TOKEN)
# Obter em: mercadopago.com.br/developers > Suas integrações > [app] > Credenciais > Public Key
# Sandbox:   TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Produção:  APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Backend PHP (criar .env ou definir via cPanel > PHP Settings) ────────────
DB_HOST=localhost
DB_NAME=alvar028_casamentos
DB_USER=alvar028_user
DB_PASS=sua_senha_mysql

# Chave mestra para criar novos casais via POST /api/couples
MASTER_API_KEY=chave_secreta_longa_aqui

# Mercado Pago — obter em mercadopago.com.br/developers > Suas integrações
# Formato: APP_USR-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx
MP_ACCESS_TOKEN=APP_USR-SEU_TOKEN_AQUI

# Segredo do webhook MP — configurar em MP > Suas integrações > Webhooks > Segredo
MP_WEBHOOK_SECRET=seu_segredo_webhook

# URL pública do site (sem barra final) — usada nos back_urls do MP
SITE_URL=https://seudominio.com.br

# true = usa sandbox MP (teste), false = produção
MP_SANDBOX=true
